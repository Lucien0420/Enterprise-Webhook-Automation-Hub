# Copy to .env and fill in values
# cp .env.example .env

# API key for X-API-KEY header validation
API_KEY=your-secret-api-key-here

# Discord webhook URL for high-value order alerts
# Get from: Discord channel → Edit → Integrations → Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxx/yyyyy

# Optional: alert threshold (default 1000)
# ALERT_THRESHOLD=1000

# Optional: requests per minute limit (default 60)
# RATE_LIMIT_PER_MINUTE=60

# Optional: database path (default: ./data/webhook_orders.db)
# DATABASE_URL=sqlite:///./data/webhook_orders.db
